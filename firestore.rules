rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // O app publicado no GitHub Pages acessa o Firebase pelo navegador.
    // Ele usa Firebase Authentication anonimo antes de ler/gravar estes dados.
    match /appSnapshots/{documentId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
